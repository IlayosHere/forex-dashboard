# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=forex
POSTGRES_USER=forex
POSTGRES_PASSWORD=change_me_in_production

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Constructed automatically by docker-compose from the Postgres vars above.
# Only override here if you are running the API outside of Docker Compose.
# DATABASE_URL=postgresql://forex:change_me_in_production@localhost:5432/forex

# Comma-separated list of origins the browser may call the API from.
# Dev:  http://localhost:3000
# Prod: your VPS domain or IP (e.g. http://165.22.1.2 or https://signals.example.com)
CORS_ORIGINS=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
# Required. Random secret for signing JWTs (use: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_secret

# Username for dashboard login (default: admin)
AUTH_USERNAME=admin

# Bcrypt hash of the login password. Generate with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
AUTH_PASSWORD_HASH=$2b$12$REPLACE_WITH_YOUR_BCRYPT_HASH

# ── Runner ────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Next.js UI ────────────────────────────────────────────────────────────────
# Baked into the client bundle at build time.
# Dev:  http://localhost:8000  (calls the API directly)
# Prod: your public nginx URL  (e.g. http://165.22.1.2 — nginx proxies /api/ → api:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
